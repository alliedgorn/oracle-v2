{
  "name": "oracle-v2",
  "version": "0.4.0-nightly",
  "description": "Oracle v2 - MCP Memory Layer with semantic search, philosophy, and knowledge management",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "oracle-v2": "./src/index.ts"
  },
  "files": [
    "src",
    "README.md"
  ],
  "engines": {
    "bun": ">=1.2.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Soul-Brews-Studio/oracle-v2.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "bun src/index.ts",
    "server": "bun src/server.ts",
    "server:ensure": "bun src/ensure-server.ts",
    "server:status": "bun src/ensure-server.ts --status",
    "serve": "bun dist/server.js",
    "index": "bun src/indexer.ts",
    "build": "tsc --noEmit",
    "start": "bun dist/index.js",
    "test": "bun run test:unit && bun run test:integration",
    "test:unit": "ORACLE_DB_PATH=:memory: ORACLE_DATA_DIR=/tmp/oracle-test-data bun test src/tools/__tests__/ src/server/__tests__/ src/vault/__tests__/ src/drizzle-migration.test.ts src/indexer-preservation.test.ts",
    "test:integration": "ORACLE_DB_PATH=:memory: ORACLE_DATA_DIR=/tmp/oracle-test-data bun test src/integration/",
    "test:integration:db": "ORACLE_DB_PATH=:memory: ORACLE_DATA_DIR=/tmp/oracle-test-data bun test src/integration/database.test.ts",
    "test:integration:mcp": "ORACLE_DB_PATH=:memory: ORACLE_DATA_DIR=/tmp/oracle-test-data bun test src/integration/mcp.test.ts",
    "test:integration:http": "ORACLE_DB_PATH=:memory: ORACLE_DATA_DIR=/tmp/oracle-test-data bun test src/integration/http.test.ts",
    "test:seed": "bun scripts/seed-test-data.ts",
    "test:coverage": "ORACLE_DB_PATH=:memory: ORACLE_DATA_DIR=/tmp/oracle-test-data bun test --coverage",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate",
    "db:push": "bunx drizzle-kit push",
    "db:pull": "bunx drizzle-kit pull",
    "db:studio": "bunx drizzle-kit studio",
    "setup": "./scripts/setup.sh",
    "vault:init": "bun src/vault/cli.ts init",
    "vault:sync": "bun src/vault/cli.ts sync",
    "vault:pull": "bun src/vault/cli.ts pull",
    "vault:status": "bun src/vault/cli.ts status",
    "vault:migrate": "bun src/vault/cli.ts migrate",
    "vault:rsync": "./scripts/vault-rsync.sh"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.3.0",
    "@lancedb/lancedb": "^0.26.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@qdrant/js-client-rest": "^1.17.0",
    "commander": "^14.0.3",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.15",
    "meilisearch": "^0.56.0",
    "sharp": "^0.34.5",
    "sqlite-vec": "^0.1.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.19.39",
    "better-sqlite3": "^12.9.0",
    "bun-types": "^1.3.13",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "undici": "^6.24.0",
    "express-rate-limit": "^8.2.2",
    "path-to-regexp": "^8.4.0",
    "esbuild": "^0.25.0"
  },
  "keywords": [
    "oracle",
    "mcp",
    "memory",
    "knowledge-base",
    "semantic-search"
  ],
  "author": "Nat's Agents",
  "license": "MIT"
}
